            "amount": 2,
            "unit": "stalks",
            "notes": "chopped"
        }
    ],
    "instructions": [
        {
            "step": 1,
            "description": "Blanch tofu cubes in lightly salted water."
        },
        {
            "step": 2,
            "description": "Fry ground pork until browned."
        },
        {
            "step": 3,
            "description": "Add Doubanjiang and stir-fry until oil turns red."
        },
        {
            "step": 4,
            "description": "Add tofu and water, simmer for 5 minutes."
        },
        {
            "step": 5,
            "description": "Thicken with cornstarch slurry and sprinkle with peppercorn powder."
