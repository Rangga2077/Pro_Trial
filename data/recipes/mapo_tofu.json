        },
        {
            "name": "Ground Pork",
            "amount": 100,
            "unit": "g"
        },
        {
            "name": "Doubanjiang (Spicy Bean Paste)",
            "amount": 2,
            "unit": "tbsp"
        },
        {
            "name": "Szechuan Peppercorn Powder",
            "amount": 1,
            "unit": "tsp"
        },
        {
